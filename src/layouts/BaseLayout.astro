---
import '../styles/global.css';
import { t, pathForLang } from '../i18n';
import type { Lang } from '../i18n';
import mapsData from '../data/maps_data.json';

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  currentPath?: string;
}

const {
  title = 'OpenFront Atlas',
  description = 'Interactive map companion for OpenFront.io — explore current battlefields with real geography, history, and strategy.',
  lang = 'en',
  currentPath = '/',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const activeMapCount = Object.keys(mapsData).length;
const enUrl = pathForLang('en', currentPath, base);
const frUrl = pathForLang('fr', currentPath, base);

const normalizedPath = currentPath === '' ? '/' : currentPath;
const isOverview = normalizedPath === '/';
const isEarth = normalizedPath === '/earth/';
const isWorlds = normalizedPath === '/worlds/';
const isArcade = normalizedPath === '/arcade/';
const isLegacy = normalizedPath === '/legacy/';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${base}images/Favicon.svg`} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="fr" href={frUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <!-- Umami Analytics -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="66db9bd7-2405-4338-a16e-1661d0a462d6"></script>
  <!-- No-flash theme init: runs before paint -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 border-b nav-bar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <!-- Logo -->
        <a href={lang === 'fr' ? `${base}fr/` : base} class="flex items-center gap-2.5">
          <img src={`${base}images/OpenFrontLogo.svg`} alt="OpenFront" class="w-7 h-7 opacity-90" />
          <span class="text-base font-semibold tracking-tight" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">
            OpenFront <span style="color: var(--accent-primary);">Atlas</span>
          </span>
        </a>

        <!-- Nav links + lang switcher -->
        <div class="flex items-center gap-1">
          <div class="hidden sm:flex items-center gap-1 mr-2">
            <a href={lang === 'fr' ? `${base}fr/` : base} class={`nav-link ${isOverview ? 'nav-link-active' : ''}`}>{t(lang, 'nav.overview')}</a>
            <a href={lang === 'fr' ? `${base}fr/earth/` : `${base}earth/`} class={`nav-link ${isEarth ? 'nav-link-active' : ''}`}>{t(lang, 'nav.earthMaps')}</a>
            <a href={lang === 'fr' ? `${base}fr/worlds/` : `${base}worlds/`} class={`nav-link ${isWorlds ? 'nav-link-active' : ''}`}>{t(lang, 'nav.otherWorlds')}</a>
            <a href={lang === 'fr' ? `${base}fr/arcade/` : `${base}arcade/`} class={`nav-link ${isArcade ? 'nav-link-active' : ''}`}>{t(lang, 'nav.arcade')}</a>
            <a href={lang === 'fr' ? `${base}fr/legacy/` : `${base}legacy/`} class={`nav-link ${isLegacy ? 'nav-link-active' : ''}`}>{t(lang, 'nav.legacy')}</a>
          </div>

          <!-- Language switcher -->
          <div class="flex items-center rounded-lg border overflow-hidden" style="border-color: var(--border); background: var(--surface);">
            <a href={enUrl} class={`lang-btn ${lang === 'en' ? 'lang-active' : ''}`}>EN</a>
            <span style="width: 1px; background: var(--border); height: 16px; display: inline-block;"></span>
            <a href={frUrl} class={`lang-btn ${lang === 'fr' ? 'lang-active' : ''}`}>FR</a>
          </div>

          <!-- Theme toggle -->
          <button id="theme-toggle" aria-label="Toggle light/dark mode" title="Toggle theme">
            <span id="theme-icon">🌙</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile nav (small screens) -->
    <div class="sm:hidden border-t px-4 py-2 flex items-center gap-3 text-xs overflow-x-auto" style="border-color: var(--border);">
      <a href={lang === 'fr' ? `${base}fr/earth/` : `${base}earth/`} class={`mobile-nav-link ${isEarth ? 'mobile-nav-link-active' : ''}`}>{t(lang, 'nav.earthMaps')}</a>
      <a href={lang === 'fr' ? `${base}fr/worlds/` : `${base}worlds/`} class={`mobile-nav-link ${isWorlds ? 'mobile-nav-link-active' : ''}`}>{t(lang, 'nav.otherWorlds')}</a>
      <a href={lang === 'fr' ? `${base}fr/arcade/` : `${base}arcade/`} class={`mobile-nav-link ${isArcade ? 'mobile-nav-link-active' : ''}`}>{t(lang, 'nav.arcade')}</a>
      <a href={lang === 'fr' ? `${base}fr/legacy/` : `${base}legacy/`} class={`mobile-nav-link ${isLegacy ? 'mobile-nav-link-active' : ''}`}>{t(lang, 'nav.legacy')}</a>
    </div>
  </nav>

  <!-- Page content -->
  <main>
    <slot />
  </main>

  <script is:inline>
    (function() {
      var BASE = document.documentElement.dataset.base ||
                 (function(){
                   var s=document.querySelector('link[rel="icon"]');
                   if(!s) return '/';
                   var href=s.getAttribute('href')||'/';
                   return href.replace(/images\/Favicon\.svg$/,'');
                 })();

      function getTheme() {
        return document.documentElement.getAttribute('data-theme') || 'dark';
      }

      function swapThumbnails(theme) {
        var imgs = document.querySelectorAll('img');
        imgs.forEach(function(img) {
          var src = img.src || '';
          if (src.indexOf('/thumbnails/') !== -1 && src.indexOf('/thumbnails-dark/') === -1) {
            if (theme === 'dark') {
              img.src = src.replace('/thumbnails/', '/thumbnails-dark/');
            }
          } else if (src.indexOf('/thumbnails-dark/') !== -1) {
            if (theme === 'light') {
              img.src = src.replace('/thumbnails-dark/', '/thumbnails/');
            }
          }
        });
      }

      function setTheme(t) {
        document.documentElement.setAttribute('data-theme', t);
        localStorage.setItem('theme', t);
        var icon = document.getElementById('theme-icon');
        if (icon) icon.textContent = t === 'dark' ? '🌙' : '☀️';
        swapThumbnails(t);
      }

      // Set initial icon
      var icon = document.getElementById('theme-icon');
      if (icon) icon.textContent = getTheme() === 'dark' ? '🌙' : '☀️';

      // Swap thumbnails on initial load if dark
      if (getTheme() === 'dark') {
        // Run after images are in DOM
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() { swapThumbnails('dark'); });
        } else {
          swapThumbnails('dark');
        }
      }

      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function() {
          setTheme(getTheme() === 'dark' ? 'light' : 'dark');
        });
      }
    })();
  </script>

  <!-- Footer -->
  <footer class="mt-24 border-t py-10" style="border-color: var(--border);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <img src={`${base}images/OpenFrontLogo.svg`} alt="OpenFront" class="w-5 h-5 opacity-60" />
        <span class="text-sm" style="color: var(--text-muted);">OpenFront Atlas — {t(lang, 'footer.tagline')}</span>
      </div>
      <div class="flex items-center gap-4 text-sm" style="color: var(--text-muted);">
        <a href="https://openfront.io" target="_blank" rel="noopener" class="hover:underline" style="color: var(--accent-primary);">OpenFront.io</a>
        <span>·</span>
        <a href="https://github.com/hfichter/openfront-atlas" target="_blank" rel="noopener" class="hover:underline" style="color: var(--text-muted);">GitHub</a>
        <span>·</span>
        <span>{activeMapCount} {t(lang, 'footer.maps')}</span>
        <span>·</span>
        <span>{t(lang, 'footer.unofficial')}</span>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
.nav-bar {
  background: rgba(5,9,19,0.92);
  border-color: var(--border);
  backdrop-filter: blur(16px);
}
[data-theme="light"] .nav-bar {
  background: rgba(244,246,251,0.92);
}
.nav-link {
  padding: 0.375rem 0.75rem;
  border-radius: 0.375rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-secondary);
  transition: color 0.15s, background 0.15s;
  text-decoration: none;
  white-space: nowrap;
}
.nav-link:hover {
  color: var(--text-primary);
  background: rgba(119, 224, 255, 0.06);
}
.nav-link-active {
  color: var(--accent-primary);
  background: rgba(119, 224, 255, 0.1);
}
.mobile-nav-link {
  color: var(--text-secondary);
  text-decoration: none;
  white-space: nowrap;
  padding: 0.25rem 0.5rem;
  border-radius: 0.375rem;
}
.mobile-nav-link-active {
  color: var(--accent-primary);
  background: rgba(119, 224, 255, 0.1);
}
.lang-btn {
  padding: 0.25rem 0.6rem;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.15s, background 0.15s;
}
.lang-btn:hover {
  color: var(--text-primary);
  background: rgba(119, 224, 255, 0.06);
}
.lang-active {
  color: var(--accent-primary) !important;
  background: rgba(119, 224, 255, 0.1) !important;
}
</style>
