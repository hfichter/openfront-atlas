---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NationsGrid from '../../components/NationsGrid';
import StatsBar from '../../components/StatsBar';
import MapDrawingOverlay from '../../components/MapDrawingOverlay';
import mapsData from '../../data/maps_data.json';
import legacyMapsData from '../../data/legacy_maps_data.json';
import type { MapsData, MapEntry, Category } from '../../types';
import { t, frequencyLabel, categoryLabel } from '../../i18n';
import type { Lang } from '../../i18n';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const data = mapsData as unknown as MapsData;
  const legacyData = legacyMapsData as unknown as MapsData;
  return [...Object.keys(data), ...Object.keys(legacyData)].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const data = mapsData as unknown as MapsData;
const legacyData = legacyMapsData as unknown as MapsData;
const map: MapEntry = data[slug!] || legacyData[slug!];
const base = import.meta.env.BASE_URL;
const lang: Lang = 'en';
const isLegacy = Boolean(legacyData[slug!]);

if (!map) return Astro.redirect(`${base}`);

let Content: any = null;
let tagline: string = '';
try {
  const allContent = await getCollection('maps');
  const entry = allContent.find(e => e.id === slug || e.data.slug === slug);
  if (entry) {
    const rendered = await render(entry);
    Content = rendered.Content;
    tagline = entry.data.tagline || '';
  }
} catch (_) {}

const categoryColor: Record<Category, string> = {
  continental: '#77e0ff', regional: '#34d399', fantasy: '#a78bfa',
  arcade: '#fbbf24', tournament: '#f87171',
};
const color = isLegacy ? '#94a3b8' : categoryColor[map.category];
const freqLabel = frequencyLabel(lang, map.playlist_frequency);
const isEarth = map.category === 'continental' || map.category === 'regional';
const isArcadeTournament = map.category === 'arcade' || map.category === 'tournament';
---

<BaseLayout
  title={`${map.translated_name || map.display_name} — OpenFront Atlas`}
  description={`${map.translated_name || map.display_name}: ${map.width}×${map.height}, ${map.land_pct.toFixed(0)}% land, ${map.nation_count} nations.`}
  lang="en"
  currentPath={`/map/${slug}/`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-6">
    <a href={`${base}${isLegacy ? 'legacy' : isArcadeTournament ? 'arcade' : isEarth ? 'earth' : 'worlds'}/`} class="inline-flex items-center gap-1.5 text-sm transition-colors" style="color: var(--text-muted);" onmouseover="this.style.color='var(--accent-primary)'" onmouseout="this.style.color='var(--text-muted)'">
      {isLegacy ? t(lang, 'back.legacy') : isArcadeTournament ? t(lang, 'back.arcade') : isEarth ? t(lang, 'back.earth') : t(lang, 'back.worlds')}
    </a>
  </div>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-5 pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-8 items-start">
      <div class="hero-thumb-wrap rounded-2xl overflow-hidden border" style="border-color: var(--border-strong); background: var(--surface);">
        <div class="hero-map-stage" style={`aspect-ratio: ${map.width} / ${map.height}; position: relative;`}>
          <img
            src={`${base}thumbnails/${slug}.webp`}
            alt={map.translated_name || map.display_name}
            class="hero-thumb"
            style={`aspect-ratio: ${map.width} / ${map.height};`}
          />

          {map.nations && map.nations.length > 0 && (
            <div id="nation-overlay" class="nation-overlay" aria-label="Nation spawn locations">
              {map.nations.map((nation) => (
                <button
                  type="button"
                  class="nation-marker"
                  style={`left: ${(nation.x / map.width) * 100}%; top: ${(nation.y / map.height) * 100}%;`}
                  aria-label={nation.name}
                >
                  {nation.flag ? (
                    <img
                      class="nation-flag"
                      src={`${base}flags/${nation.flag}.svg`}
                      alt=""
                      loading="lazy"
                      onError={(e) => {
                        const t = e.target as HTMLImageElement;
                        t.style.display = 'none';
                        if (t.nextElementSibling) (t.nextElementSibling as HTMLElement).style.display = '';
                      }}
                    />
                  ) : null}
                  <span class="nation-dot" style={nation.flag ? 'display:none' : ''}></span>
                  <span class="nation-label">{nation.name}</span>
                </button>
              ))}
            </div>
          )}

          {map.nations && map.nations.length > 0 && (
            <button
              id="toggle-nation-overlay"
              type="button"
              class="nation-toggle-btn"
              aria-label="Toggle nation spawn locations"
              aria-pressed="true"
              data-show={t(lang, 'map.nationsVisible')}
              data-hide={t(lang, 'map.nationsHidden')}
            >
              <svg class="nation-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              <svg class="nation-toggle-icon-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
              <span class="nation-toggle-text">{t(lang, 'map.nationsVisible')}</span>
            </button>
          )}
        </div>
      </div>
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border" style={`color: ${color}; border-color: ${color}44; background: ${color}11;`}>
            {isLegacy ? t(lang, 'cat.legacy') : categoryLabel(lang, map.category)}
          </span>
          <span class="text-xs" style="color: var(--text-muted);">{freqLabel}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold mb-2" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; line-height: 1.15;">
          {map.translated_name || map.display_name}
        </h1>
        {tagline && <p class="text-base mb-5" style="color: var(--text-secondary);">{tagline}</p>}
        <div class="grid grid-cols-2 gap-3 mb-5">
          {[
            [t(lang, 'map.dimensions'), `${map.width} × ${map.height}`],
            [t(lang, 'map.nations'), map.nation_count],
            [t(lang, 'map.maxPlayers'), `~${map.estimated_max_players}`],
            [t(lang, 'map.playlist'), freqLabel],
          ].map(([label, value]) => (
            <div class="stat-box">
              <div class="stat-label">{label}</div>
              <div class="stat-value" style={label === t(lang, 'map.playlist') ? `color: ${map.playlist_frequency >= 5 ? '#34d399' : map.playlist_frequency >= 3 ? color : 'var(--text-muted)'};` : ''}>{value}</div>
            </div>
          ))}
        </div>
        <div class="rounded-xl p-4 border" style="background: var(--surface); border-color: var(--border);">
          <StatsBar client:load landPct={map.land_pct} waterPct={map.water_pct} />
        </div>
        {isLegacy && (
          <div class="legacy-note">
            <div class="legacy-note-title">{t(lang, 'cat.legacy')}</div>
            <div>{map.legacy_note}</div>
            {map.legacy_replaced_by && data[map.legacy_replaced_by] && (
              <a href={`${base}map/${map.legacy_replaced_by}/`}>{t(lang, 'legacy.replacedBy')}: {data[map.legacy_replaced_by].translated_name || data[map.legacy_replaced_by].display_name}</a>
            )}
          </div>
        )}
      </div>
    </div>

    <div class="draw-cta-wrap">
      <MapDrawingOverlay
        client:load
        slug={slug!}
        mapName={map.translated_name || map.display_name}
        mapWidth={map.width}
        mapHeight={map.height}
        thumbnailSrc={`${base}thumbnails/${slug}.webp`}
        nations={map.nations}
        base={base}
        launchLabel={t(lang, 'map.draw')}
        clearConfirm={t(lang, 'map.clearConfirm')}
      />
    </div>
  </section>

  {map.nations && map.nations.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-12">
      <h2 class="section-heading">{t(lang, 'map.nations')} <span class="section-count">{map.nations.length}</span></h2>
      <NationsGrid client:visible nations={map.nations} base={base} />
    </section>
  )}

  {Content ? (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-16">
      <div class="editorial-content"><Content /></div>
    </section>
  ) : (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 mb-16">
      <div class="rounded-xl border p-8 text-center" style="border-color: var(--border); background: var(--surface);">
        <div class="text-2xl mb-3">🗺️</div>
        <div class="font-semibold mb-2" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'map.comingSoon')}</div>
        <div class="text-sm" style="color: var(--text-muted);">{t(lang, 'map.comingSoonDesc')}</div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
/* Hero thumbnail — display at native aspect ratio, no upscale blur */
.hero-thumb-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200px;
}
.hero-map-stage {
  position: relative;
  width: 100%;
}
.hero-thumb {
  display: block;
  width: 100%;
  height: auto;
  max-width: 100%;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}
.nation-overlay {
  position: absolute;
  inset: 0;
}
.is-hidden { display: none; }
.nation-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.nation-overlay .nation-marker {
  pointer-events: auto;
}
.legacy-note {
  margin-top: 1rem;
  padding: 0.875rem 1rem;
  border-radius: 0.625rem;
  border: 1px solid rgba(148,163,184,0.25);
  background: rgba(148,163,184,0.08);
  color: var(--text-secondary);
  font-size: 0.875rem;
  line-height: 1.55;
}
.legacy-note-title {
  color: var(--text-primary);
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 600;
  margin-bottom: 0.25rem;
}
.legacy-note a {
  display: inline-block;
  margin-top: 0.5rem;
  color: var(--accent-primary);
  text-decoration: none;
}
.legacy-note a:hover {
  text-decoration: underline;
}
.nation-marker {
  position: absolute;
  transform: translate(-50%, -50%);
  background: transparent;
  border: 0;
  padding: 0;
  cursor: pointer;
}
.nation-dot {
  display: block;
  width: 0.65rem;
  height: 0.65rem;
  border-radius: 999px;
  background: var(--accent-primary);
  border: 1.5px solid rgba(255,255,255,0.85);
  box-shadow: 0 0 0 3px rgba(119, 224, 255, 0.18), 0 3px 8px rgba(0,0,0,0.25);
}
.nation-flag {
  display: block;
  width: 1.25rem;
  height: 0.85rem;
  border-radius: 3px;
  border: 1.5px solid rgba(255,255,255,0.7);
  box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  object-fit: cover;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}
.nation-label {
  position: absolute;
  left: 50%;
  bottom: calc(100% + 0.5rem);
  transform: translateX(-50%);
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  background: var(--surface-elevated);
  color: var(--text-primary);
  border: 1px solid var(--border-strong);
  border-radius: 999px;
  padding: 0.25rem 0.6rem;
  font-size: 0.72rem;
  font-weight: 600;
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  transition: opacity 0.12s ease, transform 0.12s ease;
  z-index: 10;
}
.nation-marker:hover .nation-label,
.nation-marker:focus-visible .nation-label {
  opacity: 1;
  transform: translateX(-50%) translateY(-2px);
}
.nation-marker:focus-visible {
  outline: none;
}
.nation-marker:hover .nation-label,
.nation-marker:focus-visible .nation-label {
  opacity: 1;
  transform: translateX(-50%) translateY(-2px);
}
.nation-marker:hover .nation-flag,
.nation-marker:focus-visible .nation-flag {
  transform: scale(1.18);
  box-shadow: 0 4px 16px rgba(0,0,0,0.3);
}
.nation-marker:focus-visible .nation-dot {
  box-shadow: 0 0 0 4px rgba(119, 224, 255, 0.3), 0 0 0 7px rgba(119, 224, 255, 0.15), 0 3px 8px rgba(0,0,0,0.25);
}
.nation-marker:focus-visible { outline: none; }

.nation-toggle-btn {
  position: absolute;
  top: 0.65rem;
  right: 0.65rem;
  z-index: 20;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.35rem 0.7rem 0.35rem 0.55rem;
  border-radius: 999px;
  border: 1px solid var(--border-strong);
  background: var(--surface);
  backdrop-filter: blur(12px);
  color: var(--text-secondary);
  font-size: 0.72rem;
  font-weight: 600;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(0,0,0,0.18);
  transition: background 0.15s, color 0.15s, border-color 0.15s, box-shadow 0.15s;
  white-space: nowrap;
}
.nation-toggle-btn:hover {
  background: var(--surface-elevated);
  color: var(--text-primary);
  border-color: var(--accent-primary);
  box-shadow: 0 4px 20px rgba(0,0,0,0.22);
}
.nation-toggle-btn[aria-pressed="false"] { color: var(--text-muted); }
.nation-toggle-btn[aria-pressed="false"]:hover { color: var(--text-primary); }
.nation-toggle-icon { width: 0.9rem; height: 0.9rem; flex-shrink: 0; }
.nation-toggle-btn[aria-pressed="false"] .nation-toggle-icon { display: none; }
.nation-toggle-btn[aria-pressed="false"] .nation-toggle-icon-off { display: block; width: 0.9rem; height: 0.9rem; flex-shrink: 0; }

.stat-box { padding: 0.75rem 1rem; border-radius: 0.625rem; border: 1px solid var(--border); background: var(--surface); }
.stat-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.25rem; font-weight: 500; }
.stat-value { font-size: 1rem; font-weight: 600; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; }
.section-heading { font-size: 1.125rem; font-weight: 600; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
.section-count { font-size: 0.8rem; font-weight: 500; color: var(--text-muted); background: var(--surface); border: 1px solid var(--border); padding: 0.1rem 0.5rem; border-radius: 999px; }
.editorial-content :global(h2) { font-size: 1.375rem; font-weight: 700; color: var(--text-primary); font-family: 'Space Grotesk', sans-serif; margin-top: 2.5rem; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
.editorial-content :global(h3) { font-size: 1.05rem; font-weight: 600; color: var(--accent-primary); font-family: 'Space Grotesk', sans-serif; margin-top: 1.75rem; margin-bottom: 0.5rem; }
.editorial-content :global(p) { color: var(--text-secondary); line-height: 1.75; margin-bottom: 1rem; font-size: 0.95rem; }
.editorial-content :global(ul) { list-style: none; padding: 0; margin-bottom: 1rem; }
.editorial-content :global(ul li) { color: var(--text-secondary); font-size: 0.95rem; padding: 0.35rem 0 0.35rem 1.25rem; position: relative; line-height: 1.6; }
.editorial-content :global(ul li::before) { content: '·'; position: absolute; left: 0; color: var(--accent-primary); font-weight: 700; }
.editorial-content :global(strong) { color: var(--text-primary); font-weight: 600; }
.editorial-content :global(blockquote) { border-left: 3px solid var(--accent-primary); padding: 0.75rem 1rem; margin: 1.5rem 0; border-radius: 0 0.5rem 0.5rem 0; background: rgba(119, 224, 255, 0.05); color: var(--text-secondary); font-style: italic; }
</style>

<script is:inline>
(function() {
  var btn = document.getElementById('toggle-nation-overlay');
  var overlay = document.getElementById('nation-overlay');
  if (!btn || !overlay) return;

  function updateToggle(pressed) {
    btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
    var label = btn.querySelector('.nation-toggle-text');
    if (label) label.textContent = pressed ? btn.dataset.show : btn.dataset.hide;
    overlay.classList.toggle('is-hidden', !pressed);
  }

  btn.addEventListener('click', function() {
    var isPressed = btn.getAttribute('aria-pressed') !== 'false';
    updateToggle(!isPressed);
  });
  btn.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      var isPressed = btn.getAttribute('aria-pressed') !== 'false';
      updateToggle(!isPressed);
    }
  });
})();
</script>
