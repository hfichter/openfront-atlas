---
import BaseLayout from '../layouts/BaseLayout.astro';
import mapsData from '../data/maps_data.json';
import type { MapsData } from '../types';
import { t } from '../i18n';
import type { Lang } from '../i18n';

export interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;

const data = mapsData as unknown as MapsData;
const base = import.meta.env.BASE_URL;
const prefix = lang === 'fr' ? `${base}fr/` : base;

const worldsMaps = Object.entries(data).filter(([, m]) => m.category === 'fantasy');
const featuredSlugs = ['mars', 'pangaea', 'pluto', 'milkyway'];
const featured = featuredSlugs.map(s => [s, data[s]] as [string, typeof data[string]]).filter(([, m]) => m);
---

<BaseLayout
  title={lang === 'fr' ? 'Autres Mondes — OpenFront Atlas' : 'Other Worlds — OpenFront Atlas'}
  lang={lang}
  currentPath="/worlds/"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-2xl">🪐</span>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'nav.otherWorlds')}</h1>
    </div>
    <p class="text-base" style="color: var(--text-secondary);">
      {worldsMaps.length} {t(lang, 'worlds.subtitle')}
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
    <div class="text-xs uppercase tracking-widest mb-4 font-medium" style="color: var(--text-muted);">{t(lang, 'worlds.featured')}</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {featured.map(([slug, map]) => (
        <a href={`${prefix}map/${slug}/`} class="feature-card group block rounded-xl overflow-hidden border">
          <div class="relative overflow-hidden" style="aspect-ratio: 16/9;">
            <img src={`${base}thumbnails/${slug}.webp`} alt={map.translated_name || map.display_name} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(5,9,19,0.8) 0%, transparent 60%);" />
            <span class="absolute bottom-2 left-3 font-semibold text-sm" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{map.translated_name || map.display_name}</span>
          </div>
          <div class="p-3 flex items-center justify-between">
            <div class="text-xs" style="color: var(--text-muted);">{map.nation_count} {t(lang, 'map.nations').toLowerCase()} · ~{map.estimated_max_players} {t(lang, 'wmap.players')}</div>
            <span class="text-xs px-2 py-0.5 rounded-full border badge-fantasy">{t(lang, 'cat.fantasy')}</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <h2 class="text-lg font-semibold mb-5" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'worlds.all')}</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {worldsMaps.map(([slug, map]) => (
        <a href={`${prefix}map/${slug}/`} class="map-thumb-card group block rounded-xl overflow-hidden border">
          <div class="relative" style="aspect-ratio: 4/3;">
            <img src={`${base}thumbnails/${slug}.webp`} alt={map.translated_name || map.display_name} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(5,9,19,0.7) 0%, transparent 55%);" />
          </div>
          <div class="p-2.5">
            <div class="text-xs font-semibold truncate" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{map.translated_name || map.display_name}</div>
            <div class="text-xs mt-0.5" style="color: var(--text-muted);">{map.land_pct.toFixed(0)}% {t(lang, 'wmap.land')} · {map.nation_count} {t(lang, 'map.nations').toLowerCase()}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.feature-card { background: var(--surface-elevated); border-color: var(--border); text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s; }
.feature-card:hover { border-color: rgba(167,139,250,0.35); box-shadow: 0 0 18px rgba(167,139,250,0.1); }
.map-thumb-card { background: var(--surface-elevated); border-color: var(--border); text-decoration: none; transition: border-color 0.15s; }
.map-thumb-card:hover { border-color: rgba(167,139,250,0.3); }
</style>
