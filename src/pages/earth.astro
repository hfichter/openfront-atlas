---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorldMap from '../components/WorldMap';
import mapsData from '../data/maps_data.json';
import type { MapsData } from '../types';
import { t } from '../i18n';
import type { Lang } from '../i18n';

export interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;

const data = mapsData as unknown as MapsData;
const base = import.meta.env.BASE_URL;
const prefix = lang === 'fr' ? `${base}fr/` : base;

const earthMaps = Object.entries(data).filter(([, m]) =>
  m.category === 'continental' || m.category === 'regional'
);
const globalMaps = earthMaps.filter(([, m]) => m.geo_type === 'global');
const hasGeo = (m: { geo_lat?: number; geo_lng?: number }) => m.geo_lat != null && m.geo_lng != null;
const continentMaps = earthMaps.filter(([, m]) => m.geo_type === 'continent' && hasGeo(m)).map(([slug, map]) => ({ slug, map }));
const regionalPins = earthMaps.filter(([, m]) => m.geo_type === 'regional' && hasGeo(m)).map(([slug, map]) => ({ slug, map }));
const continentals = earthMaps.filter(([, m]) => m.category === 'continental');
const regionals = earthMaps.filter(([, m]) => m.category === 'regional');
---

<BaseLayout
  title={lang === 'fr' ? 'Cartes Terrestres — OpenFront Atlas' : 'Earth Maps — OpenFront Atlas'}
  lang={lang}
  currentPath="/earth/"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-2xl">🌍</span>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'nav.earthMaps')}</h1>
    </div>
    <p class="text-base" style="color: var(--text-secondary);">
      {earthMaps.length} {t(lang, 'earth.subtitle')}
    </p>
  </div>

  {globalMaps.length > 0 && (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
      <div class="text-xs uppercase tracking-widest mb-3 font-medium" style="color: var(--text-muted);">{t(lang, 'earth.globalScale')}</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {globalMaps.map(([slug, map]) => (
          <a href={`${prefix}map/${slug}/`} class="global-card group flex gap-4 rounded-xl border p-4">
            <img src={`${base}thumbnails/${slug}.webp`} alt={map.translated_name || map.display_name} class="w-32 h-20 object-cover rounded-lg flex-shrink-0" />
            <div>
              <div class="font-semibold mb-1" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{map.translated_name || map.display_name}</div>
              <div class="text-sm" style="color: var(--text-muted);">{map.width}×{map.height} · {map.nation_count} {t(lang, 'map.nations').toLowerCase()} · ~{map.estimated_max_players} {t(lang, 'wmap.players')}</div>
              <div class="mt-2 text-xs" style="color: var(--accent-primary);">{t(lang, 'earth.explore')}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
    <div class="text-xs uppercase tracking-widest mb-3 font-medium" style="color: var(--text-muted);">{t(lang, 'earth.mapNote')}</div>
    <div class="hidden md:block">
      <WorldMap client:load pins={regionalPins} continents={continentMaps} base={prefix} />
    </div>
    <div class="md:hidden text-sm text-center py-6 rounded-xl border" style="color: var(--text-muted); border-color: var(--border); background: var(--surface);">
      {t(lang, 'earth.mobileNote')}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
    <h2 class="text-lg font-semibold mb-5" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'earth.continental')}</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {continentals.map(([slug, map]) => (
        <a href={`${prefix}map/${slug}/`} class="map-thumb-card group block rounded-xl overflow-hidden border">
          <div class="relative" style="aspect-ratio: 4/3;">
            <img src={`${base}thumbnails/${slug}.webp`} alt={map.translated_name || map.display_name} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(5,9,19,0.7) 0%, transparent 55%);" />
          </div>
          <div class="p-3">
            <div class="text-xs font-semibold truncate" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{map.translated_name || map.display_name}</div>
            <div class="text-xs mt-0.5" style="color: var(--text-muted);">{map.nation_count} {t(lang, 'map.nations').toLowerCase()}</div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <h2 class="text-lg font-semibold mb-5" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'earth.regional')} <span class="text-sm font-normal ml-2" style="color: var(--text-muted);">{regionals.length}</span></h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
      {regionals.map(([slug, map]) => (
        <a href={`${prefix}map/${slug}/`} class="map-thumb-card group block rounded-xl overflow-hidden border">
          <div class="relative" style="aspect-ratio: 4/3;">
            <img src={`${base}thumbnails/${slug}.webp`} alt={map.translated_name || map.display_name} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(5,9,19,0.7) 0%, transparent 55%);" />
          </div>
          <div class="p-2.5">
            <div class="text-xs font-semibold truncate" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{map.translated_name || map.display_name}</div>
            <div class="text-xs mt-0.5" style="color: var(--text-muted);">{map.nation_count} {t(lang, 'map.nations').toLowerCase()}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.global-card { background: var(--surface-elevated); border-color: var(--border); text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s; }
.global-card:hover { border-color: rgba(119,224,255,0.3); box-shadow: 0 0 20px rgba(119,224,255,0.08); }
.map-thumb-card { background: var(--surface-elevated); border-color: var(--border); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s; }
.map-thumb-card:hover { border-color: rgba(119,224,255,0.3); box-shadow: 0 0 14px rgba(119,224,255,0.07); }
</style>
