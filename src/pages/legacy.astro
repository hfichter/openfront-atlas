---
import BaseLayout from '../layouts/BaseLayout.astro';
import mapsData from '../data/maps_data.json';
import legacyMapsData from '../data/legacy_maps_data.json';
import type { MapsData } from '../types';
import { t, mapLabel } from '../i18n';
import type { Lang } from '../i18n';

export interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;

const activeData = mapsData as unknown as MapsData;
const legacyData = legacyMapsData as unknown as MapsData;
const legacyMaps = Object.entries(legacyData);
const base = import.meta.env.BASE_URL;
const prefix = lang === 'fr' ? `${base}fr/` : base;
---

<BaseLayout
  title={lang === 'fr' ? 'Cartes archivées - OpenFront Atlas' : 'Legacy Maps - OpenFront Atlas'}
  lang={lang}
  currentPath="/legacy/"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
    <div class="flex items-center gap-3 mb-2">
      <span class="legacy-mark">L</span>
      <h1 class="text-3xl font-bold" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{t(lang, 'legacy.maps')}</h1>
    </div>
    <p class="text-base" style="color: var(--text-secondary);">
      {legacyMaps.length} {t(lang, 'legacy.subtitle')}
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {legacyMaps.map(([slug, map]) => {
        const replacement = map.legacy_replaced_by ? activeData[map.legacy_replaced_by] : null;
        return (
          <a href={`${prefix}map/${slug}/`} class="legacy-card group block rounded-xl overflow-hidden border">
            <div class="relative overflow-hidden" style="aspect-ratio: 16/9;">
              <img src={`${base}thumbnails/${slug}.webp`} alt={mapLabel(lang, slug, map.display_name, map.translated_name)} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(5,9,19,0.72) 0%, transparent 55%);" />
              <span class="absolute top-2 left-2 text-xs px-2 py-0.5 rounded-full border badge-legacy">{t(lang, 'cat.legacy')}</span>
            </div>
            <div class="p-4">
              <div class="font-semibold mb-1" style="color: var(--text-primary); font-family: 'Space Grotesk', sans-serif;">{mapLabel(lang, slug, map.display_name, map.translated_name)}</div>
              <div class="text-sm mb-3" style="color: var(--text-muted);">{map.legacy_note}</div>
              <div class="grid grid-cols-2 gap-2 text-xs" style="color: var(--text-muted);">
                <div>{t(lang, 'legacy.removedSync')}: {map.legacy_removed_sync}</div>
                {replacement && (
                  <div>{t(lang, 'legacy.replacedBy')}: {mapLabel(lang, map.legacy_replaced_by!, replacement.display_name, replacement.translated_name)}</div>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
.legacy-card {
  background: var(--surface-elevated);
  border-color: var(--border);
  text-decoration: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.legacy-card:hover {
  border-color: rgba(148,163,184,0.35);
  box-shadow: 0 0 18px rgba(148,163,184,0.1);
}
.legacy-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.75rem;
  height: 1.75rem;
  border-radius: 0.375rem;
  border: 1px solid var(--border);
  color: var(--text-muted);
  background: var(--surface);
  font-size: 0.875rem;
  font-weight: 700;
  font-family: 'Space Grotesk', sans-serif;
}
</style>
